    {
      "parameters": {
        "jsCode": "const mainItem = items[0];\nconst text = String(mainItem?.json?.text ?? \"\");\n\n// Проверяем, что текст начинается со строки \"Заполнения \"\n// - допускаем пробелы/переносы в начале\n// - требуем пробел после слова (как ты просил)\n// - регистр не важен\nconst startsWithZapolneniya = /^\\s*Заполнения\\s+/i.test(text);\n\n// Вариант: вернем \"clean_text\", чтобы дальше было стабильнее (без BOM)\nconst clean_text = text.replace(/^\\uFEFF/, \"\"); // если вдруг прилетел BOM\n\nreturn [\n  {\n    json: {\n      starts_with_zapolneniya: startsWithZapolneniya,\n      // можно пригодится в логах\n      first_line: clean_text.split(/\\r?\\n/)[0] ?? \"\",\n      // чтобы следующая нода брала именно его:\n      text: clean_text,\n    },\n  },\n];"
      },
