    {
      "parameters": {
        "jsCode": "/**\n * Парсит текст и возвращает items в формате колонок qual_analize_pos.\n */\n\nconst mainItem = items[0];\nconst text = String(mainItem?.json?.text ?? \"\");\n\n// Номер: допускаем пробелы/переносы внутри (после дефиса часто бывает перенос)\nconst ITEM_RE =\n  /(\\d{2}-\\d{3}-\\s*\\d{4}\\/\\d+\\/\\d+)\\s+([\\s\\S]*?)\\s*\\((\\d+)\\)\\s*мм\\s+(\\d+)\\s*[x×]\\s*(\\d+)\\s+(\\d+)\\s+([\\d.,]+)\\s+([\\d.,]+)/gi;\n\nconst LAYOUT_RE = /Раскладка\\s+([^\\r\\n]+)/i;\n\n// PARSE\nconst blocks = text.split(/Итого по изделию:/i);\nconst outputItems = [];\n\nfor (const block of blocks) {\n  const r = block.match(LAYOUT_RE);\n  const layout = r ? r[1].trim() : null;\n\n  ITEM_RE.lastIndex = 0;\n  let m;\n\n  while ((m = ITEM_RE.exec(block)) !== null) {\n    // номер может быть \"18-102-\\n1002/1/5\" — склеиваем\n    const номер = String(m[1]).replace(/\\s+/g, \"\").trim();\n\n    // формула может быть многострочной/с пробелами — прибираем лишние переносы\n    const формула = String(m[2]).replace(/\\s+/g, \" \").trim();\n\n    const толщина_мм = parseInt(m[3], 10);\n\n    const ширина = parseInt(m[4], 10);\n    const высота = parseInt(m[5], 10);\n\n    const количество = parseInt(m[6], 10);\n    const площадь = parseFloat(String(m[7]).replace(\",\", \".\"));\n    const масса = parseFloat(String(m[8]).replace(\",\", \".\"));\n\n    outputItems.push({\n      position_num: номер,\n      position_formula: формула,\n      position_raskl: layout ?? \"отсутствует\",\n      position_width: Number.isFinite(ширина) ? ширина : null,\n      position_hight: Number.isFinite(высота) ? высота : null,\n      position_count: Number.isFinite(количество) ? количество : null,\n      position_area: Number.isFinite(площадь) ? площадь : null,\n      position_mass: Number.isFinite(масса) ? масса : null,\n      // толщина_мм если надо сохранять — добавь колонку/поле\n      // position_thickness: Number.isFinite(толщина_мм) ? толщина_мм : null,\n    });\n  }\n}\n\nreturn outputItems.map((i) => ({ json: i }));"
      },
      "type": "n8n-nodes-base.code",
